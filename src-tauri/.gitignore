# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# The generated iOS Xcode project (gen/apple) IS tracked — like gen/android — so framework additions
# (Security, MediaPlayer), DEVELOPMENT_TEAM, and other project customizations are reproducible and
# reach CI. Its build artifacts and the OAuth-id-bearing Info.plist are excluded via
# gen/apple/.gitignore.

# Generated by scripts/write-ios-plist.mjs (merged into the iOS Info.plist at build time);
# embeds the iOS OAuth client id, kept out of git like cloud_sync.config.json
/Info.ios.plist

# App icons stamped into the gen projects per channel by scripts/write-mobile-icons.mjs.
# The source of truth is icons/{dev,staging,prod}/{ios,android}/; these are derived artifacts,
# so a dev/staging/prod swap doesn't churn the working tree. (Contents.json and the Android
# values/colors|strings|themes.xml stay tracked — only the icon files vary by channel.)
/gen/apple/Assets.xcassets/AppIcon.appiconset/*.png
/gen/android/app/src/main/res/mipmap-*/ic_launcher*.png
/gen/android/app/src/main/res/mipmap-anydpi-v26/
/gen/android/app/src/main/res/values/ic_launcher_background.xml
