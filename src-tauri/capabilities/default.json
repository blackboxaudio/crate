{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "/Volumes/**" },
        { "path": "/media/**" },
        { "path": "/mnt/**" },
        { "path": "/run/media/**" },
        { "path": "?:/**" },
        { "path": "?:\\**" }
      ]
    },
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-appdata-write-recursive",
    "fs:allow-mkdir",
    "clipboard-manager:allow-write-text",
    "updater:default",
    "process:default",
    "window-state:default",
    "notification:default"
  ]
}
