{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crate",
  "version": "0.2.4",
  "identifier": "com.bbx-audio.crate",
  "build": {
    "beforeDevCommand": "yarn dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build:vite",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Crate",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; media-src 'self' http://127.0.0.1:* https:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFMzJFNEM1OTQ3MEI5N0QKUldSOXVYQ1V4ZVF5WGh2NXpGc04rTmRWQW1RcVliM2MxazJzUzczOHpCcGZsNlE2TEpyN0dzZ1YK",
      "dialog": false
    }
  }
}
